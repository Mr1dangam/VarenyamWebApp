rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any authenticated user to read/write
    // Room "security" is handled by the room password at join time

    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }

    match /rooms/{roomId}/entries/{entryId} {
      allow read, write: if request.auth != null;
    }

    match /rooms/{roomId}/history/{historyId} {
      allow read, write: if request.auth != null;
    }
  }
}